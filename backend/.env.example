# KeyForge backend environment template.
# Copy to backend/.env and fill in values, OR run `python tools/cli.py init`
# from the repo root to generate ENCRYPTION_KEY and JWT_SECRET automatically.

# MongoDB connection string. Use mongodb://mongodb:27017 inside docker-compose,
# mongodb://localhost:27017 for bare-metal local dev.
MONGO_URL="mongodb://localhost:27017"

# Database name. Must match docker-compose.yml. Do not use "test_database".
DB_NAME="keyforge"

# Fernet symmetric key used to encrypt credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or: python tools/cli.py init
# WARNING: rotating this key makes every existing credential permanently unreadable.
ENCRYPTION_KEY=""

# Secret used to sign JWT access tokens (HS256).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Or: python tools/cli.py init
JWT_SECRET=""

# Optional: set to "false" for local HTTP dev so the auth cookie is sent without TLS.
# Defaults to "true" (cookies require HTTPS), which is what production should use.
KEYFORGE_COOKIE_SECURE="true"

# Where the frontend lives. Used by the GitHub install callback to bounce the
# browser back to the dashboard after a successful or failed install.
KEYFORGE_FRONTEND_URL="http://localhost:3000"

# --- GitHub credential issuer (Tier 2.2) ---
# All five vars must be set for the GitHub issuer to be available. Without
# them, every GitHub issuer method raises IssuerNotSupported and
# /api/issuers/github/* returns 503; the rest of KeyForge boots fine.

# Numeric GitHub App ID from https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=""

# RSA private key for signing GitHub App JWTs. Either:
#   * The full PEM key as a single string starting with -----BEGIN, or
#   * An absolute filesystem path to a .pem file.
GITHUB_APP_PRIVATE_KEY=""

# OAuth credentials from the same App page. The client secret is reserved
# for user-to-server flows; KeyForge currently only uses installation
# tokens so the secret is required-but-unused.
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""

# Public app slug used to build the install URL. Falls back to
# GITHUB_APP_CLIENT_ID if unset.
GITHUB_APP_SLUG=""

# Where GitHub redirects after the user installs the App. Defaults to the
# local dev frontend.
GITHUB_APP_INSTALL_REDIRECT_URL="http://localhost:3000/integrations/github/callback"

# --- AWS STS credential issuer (Tier 2.3) ---
# boto3 is already in requirements.txt; the issuer is available whenever
# boto3 can resolve KeyForge's own AWS credentials (env vars, instance role,
# shared config, etc.). Per-user role ARNs are stored on the user document
# via POST /api/issuers/aws/configure.

# AWS region for the STS client. Falls back to AWS_DEFAULT_REGION, then
# us-east-1.
AWS_REGION="us-east-1"

# KeyForge's own AWS account id, rendered into the trust-policy template
# the frontend hands to users. Without this, the template carries a
# <KEYFORGE_AWS_ACCOUNT_ID> placeholder users have to fill in by hand.
KEYFORGE_AWS_ACCOUNT_ID=""
